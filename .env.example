# Local litellm proxy (Anthropic-compatible endpoint -> Google models)
ANTHROPIC_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=your-litellm-master-key
ANTHROPIC_API_KEY=DUMMY_KEY
ANTHROPIC_AUTH_TOKEN=DUMMY_KEY
ANTHROPIC_MODEL=gemini-3-flash

# Google AI (used by the litellm proxy in dev; users supply their own key in-app for prod)
GOOGLE_API_KEY=your-google-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# Postgres connection string (Neon or Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth app (https://github.com/settings/developers)
GITHUB_ID=""
GITHUB_SECRET=""

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=""

# 32-byte base64 secret used to encrypt user-supplied Google API keys.
# Generate with: openssl rand -base64 32
GOOGLE_KEY_ENCRYPTION_SECRET=""
